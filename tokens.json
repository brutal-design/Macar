{
  "primitives": {
    "space": {
      "6":  { "$type": "dimension", "$value": "6px" },
      "8":  { "$type": "dimension", "$value": "8px" },
      "12": { "$type": "dimension", "$value": "12px" },
      "16": { "$type": "dimension", "$value": "16px" },
      "20": { "$type": "dimension", "$value": "20px" }
    },
    "radius": {
      "sm":   { "$type": "dimension", "$value": "6px" },
      "md":   { "$type": "dimension", "$value": "8px" },
      "full": { "$type": "dimension", "$value": "9999px" }
    }
  },

  "semantic": {
    "action": {
      "primary":   { "default": { "$type": "color", "$value": "#fb7b04" } },
      "secondary": { "active":  { "$type": "color", "$value": "#6d7463" } }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "#f7f8f7" },
      "secondary": { "$type": "color", "$value": "#dcded8" },
      "muted":     { "$type": "color", "$value": "#a0a696" },
      "disabled":  { "$type": "color", "$value": "#6d7463" },
      "link":      { "$type": "color", "$value": "#cefd81" }
    },
    "bg": {
      "canvas":   { "$type": "color", "$value": "#171915" },
      "elevated": { "$type": "color", "$value": "#292c26" },
      "raised":   { "$type": "color", "$value": "#43483d" }
    },
    "border": {
      "subtle": { "$type": "color", "$value": "#43483d" }
    },
    "status": {
      "success": {
        "text":      { "$type": "color", "$value": "#c3f3d7" },
        "bg-subtle": { "$type": "color", "$value": "#0d4424" },
        "border":    { "$type": "color", "$value": "#1d914d" }
      }
    }
  },

  "component": {
    "button": {
      "primary": {
        "text": {
          "default":  { "$type": "color", "$value": "#0a0b0f" },
          "disabled": { "$type": "color", "$value": "#6d7463" }
        },
        "bg": {
          "default":  { "$type": "color", "$value": "#fb7b04" },
          "hover":    { "$type": "color", "$value": "#b4fc40" },
          "active":   { "$type": "color", "$value": "#cefd81" },
          "disabled": { "$type": "color", "$value": "#585e50" }
        }
      },
      "secondary": {
        "text":   { "$type": "color", "$value": "#f7f8f7" },
        "border": { "$type": "color", "$value": "#585e50" },
        "bg": {
          "default": { "$type": "color", "$value": "#43483d" },
          "hover":   { "$type": "color", "$value": "#585e50" },
          "active":  { "$type": "color", "$value": "#6d7463" }
        }
      },
      "ghost": {
        "text": { "$type": "color", "$value": "#f7f8f7" },
        "bg": {
          "hover": { "$type": "color", "$value": "#43483d" }
        }
      },
      "danger": {
        "text": { "$type": "color", "$value": "#0a0b0f" },
        "bg": {
          "default": { "$type": "color", "$value": "#ff0000" },
          "hover":   { "$type": "color", "$value": "#ff3d3d" },
          "active":  { "$type": "color", "$value": "#ff8080" }
        }
      }
    }
  },

  "typography": {
    "tiny-strong":    { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "10px", "lineHeight": "14px", "letterSpacing": "0px" } },
    "overline":       { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 700, "fontSize": "10px", "lineHeight": "14px", "letterSpacing": "0px" } },
    "caption":        { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 400, "fontSize": "11px", "lineHeight": "16px", "letterSpacing": "0px" } },
    "footnote":       { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 400, "fontSize": "12px", "lineHeight": "16px", "letterSpacing": "0px" } },
    "label":          { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "12px", "lineHeight": "16px", "letterSpacing": "0px" } },
    "body-xs":        { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 400, "fontSize": "13px", "lineHeight": "20px", "letterSpacing": "0px" } },
    "body-xs-strong": { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "13px", "lineHeight": "20px", "letterSpacing": "0px" } },
    "body-sm-strong": { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "14px", "lineHeight": "20px", "letterSpacing": "0px" } },
    "body-strong":    { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "16px", "lineHeight": "24px", "letterSpacing": "0px" } }
  }
}
